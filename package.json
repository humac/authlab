{
  "name": "authlab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "build:ci": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --disable-warning=ExperimentalWarning --experimental-test-module-mocks --import ./test/register-loader.mjs --test test/unit/*.test.ts",
    "test:unit:coverage": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --disable-warning=ExperimentalWarning --experimental-test-module-mocks --import ./test/register-loader.mjs --test --experimental-test-coverage test/unit/*.test.ts",
    "test:integration": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --disable-warning=ExperimentalWarning --experimental-test-module-mocks --import ./test/register-loader.mjs --import ./test/integration/setup-env.mjs --test --test-concurrency=1 test/integration/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "test:ci": "npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run prisma:validate && npm run build:ci"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-libsql": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "@types/bcryptjs": "^2.4.6",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "file-type": "^20.5.0",
    "iron-session": "^8.0.4",
    "next": "16.1.6",
    "nodemailer": "^7.0.5",
    "openid-client": "^6.8.2",
    "otplib": "^12.0.1",
    "prisma": "^7.4.2",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.4",
    "tw-elements-react": "^1.0.0-alpha-end",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
