generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  passwordHash       String
  isSystemAdmin      Boolean  @default(false)
  mustChangePassword Boolean  @default(false)
  isVerified         Boolean  @default(true)
  mfaEnabled         Boolean  @default(false)
  totpSecretEnc      String?
  totpEnabledAt      DateTime?
  defaultTeamId      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teamMemberships      TeamMember[]
  invitesSent          InviteToken[]
  joinRequests         TeamJoinRequest[] @relation("TeamJoinRequester")
  reviewedJoinRequests TeamJoinRequest[] @relation("TeamJoinReviewer")
  credentials          Credential[]
  authTokens           AuthToken[]
  profileImage         UserProfileImage?
}

model Team {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  isPersonal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members      TeamMember[]
  appInstances AppInstance[]
  inviteTokens InviteToken[]
  joinRequests TeamJoinRequest[]
}

model TeamMember {
  id       String   @id @default(cuid())
  role     TeamRole @default(MEMBER)
  userId   String
  teamId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
}

model InviteToken {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String
  role        TeamRole @default(MEMBER)
  expiresAt   DateTime
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User     @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model TeamJoinRequest {
  id           String                @id @default(cuid())
  status       TeamJoinRequestStatus @default(PENDING)
  role         TeamRole              @default(MEMBER)
  note         String?
  teamId       String
  userId       String
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  team       Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User  @relation("TeamJoinRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("TeamJoinReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([teamId, userId, status])
}

model Credential {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String @unique
  publicKey  String
  signCount  Int      @default(0)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model AuthToken {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   AuthTokenPurpose
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, purpose])
}

model UserProfileImage {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mimeType  String
  sizeBytes Int
  content   Bytes
  sha256    String
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AppInstance {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  protocol     Protocol

  // Ownership
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // OIDC Specific Fields
  issuerUrl    String?
  clientId     String?
  clientSecret String? // Encrypted at rest (AES-256-GCM)
  scopes       String? @default("openid profile email")
  customAuthParamsJson String?
  pkceMode     PkceMode @default(S256)
  usePar       Boolean @default(false)

  // SAML Specific Fields
  entryPoint   String? // Identity Provider Single Sign-On URL
  samlLogoutUrl String? // Identity Provider Single Logout URL
  issuer       String? // Service Provider Entity ID
  idpCert      String? // The IDP Public Certificate — encrypted at rest
  nameIdFormat String?
  requestedAuthnContext String?
  forceAuthnDefault Boolean @default(false)
  isPassiveDefault Boolean @default(false)
  samlSignatureAlgorithm SamlSignatureAlgorithm @default(SHA256)
  clockSkewToleranceSeconds Int @default(0)
  signAuthnRequests Boolean @default(false)
  spSigningPrivateKey String? // Encrypted at rest (AES-256-GCM)
  spSigningCert String?
  spEncryptionPrivateKey String? // Encrypted at rest (AES-256-GCM)
  spEncryptionCert String?

  // UI Customization
  buttonColor  String? @default("#3B71CA")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authRuns     AuthRun[]
  scimResources ScimResource[]
  scimRequestLogs ScimRequestLog[]
}

model AuthRun {
  id                   String        @id @default(cuid())
  appInstanceId        String
  appInstance          AppInstance   @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)
  protocol             Protocol
  grantType            AuthRunGrantType @default(AUTHORIZATION_CODE)
  status               AuthRunStatus @default(PENDING)
  loginState           String?       @unique
  nonce                String?
  nonceStatus          String?
  oidcSubject          String?
  oidcSessionId        String?
  runtimeOverridesJson String?
  outboundAuthParamsJson String?
  claimsJson           String?
  idToken              String?
  accessTokenEnc       String?
  refreshTokenEnc      String?
  accessTokenExpiresAt DateTime?
  rawTokenResponseEnc  String?
  rawSamlResponseXml   String?
  userinfoJson         String?
  lastIntrospectionJson String?
  lastRevocationAt     DateTime?
  authenticatedAt      DateTime?
  completedAt          DateTime?
  logoutState          String?       @unique
  logoutCompletedAt    DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  events               AuthRunEvent[]

  @@index([appInstanceId, createdAt])
  @@index([appInstanceId, status, oidcSessionId])
  @@index([appInstanceId, status, oidcSubject])
}

model AuthRunEvent {
  id           String             @id @default(cuid())
  authRunId    String
  authRun      AuthRun            @relation(fields: [authRunId], references: [id], onDelete: Cascade)
  type         AuthRunEventType
  status       AuthRunEventStatus @default(SUCCESS)
  requestJson  String?
  responseEnc  String?
  metadataJson String?
  occurredAt   DateTime           @default(now())
  createdAt    DateTime           @default(now())

  @@index([authRunId, occurredAt])
}

model ScimResource {
  id           String           @id @default(cuid())
  appInstanceId String
  appInstance  AppInstance      @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)
  resourceType ScimResourceType
  resourceId   String
  externalId   String?
  displayName  String?
  payloadJson  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([appInstanceId, resourceType, resourceId])
  @@index([appInstanceId, resourceType, displayName])
}

model ScimRequestLog {
  id           String           @id @default(cuid())
  appInstanceId String
  appInstance  AppInstance      @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)
  resourceType ScimResourceType?
  resourceId   String?
  method       String
  path         String
  statusCode   Int
  requestJson  String?
  responseJson String?
  createdAt    DateTime         @default(now())

  @@index([appInstanceId, createdAt])
}

enum Protocol {
  OIDC
  SAML
}

enum PkceMode {
  S256
  PLAIN
  NONE
}

enum SamlSignatureAlgorithm {
  SHA1
  SHA256
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum TeamJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthTokenPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum AuthRunStatus {
  PENDING
  AUTHENTICATED
  LOGGED_OUT
  FAILED
}

enum AuthRunGrantType {
  AUTHORIZATION_CODE
  CLIENT_CREDENTIALS
  DEVICE_AUTHORIZATION
  TOKEN_EXCHANGE
}

enum AuthRunEventType {
  AUTHORIZATION_STARTED
  AUTHENTICATED
  CLIENT_CREDENTIALS_ISSUED
  DEVICE_AUTHORIZATION_STARTED
  DEVICE_AUTHORIZATION_COMPLETED
  TOKEN_EXCHANGED
  REFRESHED
  INTROSPECTED
  REVOKED
  USERINFO_FETCHED
  FRONTCHANNEL_LOGGED_OUT
  BACKCHANNEL_LOGGED_OUT
  FAILED
}

enum AuthRunEventStatus {
  SUCCESS
  FAILED
}

enum ScimResourceType {
  USER
  GROUP
}
