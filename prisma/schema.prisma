generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  passwordHash       String
  isSystemAdmin      Boolean  @default(false)
  mustChangePassword Boolean  @default(false)
  isVerified         Boolean  @default(true)
  mfaEnabled         Boolean  @default(false)
  totpSecretEnc      String?
  totpEnabledAt      DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teamMemberships      TeamMember[]
  invitesSent          InviteToken[]
  joinRequests         TeamJoinRequest[] @relation("TeamJoinRequester")
  reviewedJoinRequests TeamJoinRequest[] @relation("TeamJoinReviewer")
  credentials          Credential[]
  authTokens           AuthToken[]
  profileImage         UserProfileImage?
}

model Team {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  isPersonal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members      TeamMember[]
  appInstances AppInstance[]
  inviteTokens InviteToken[]
  joinRequests TeamJoinRequest[]
}

model TeamMember {
  id       String   @id @default(cuid())
  role     TeamRole @default(MEMBER)
  userId   String
  teamId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
}

model InviteToken {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String
  role        TeamRole @default(MEMBER)
  expiresAt   DateTime
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User     @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model TeamJoinRequest {
  id           String                @id @default(cuid())
  status       TeamJoinRequestStatus @default(PENDING)
  role         TeamRole              @default(MEMBER)
  note         String?
  teamId       String
  userId       String
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  team       Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User  @relation("TeamJoinRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("TeamJoinReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([teamId, userId, status])
}

model Credential {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String @unique
  publicKey  String
  signCount  Int      @default(0)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model AuthToken {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   AuthTokenPurpose
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, purpose])
}

model UserProfileImage {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mimeType  String
  sizeBytes Int
  content   Bytes
  sha256    String
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AppInstance {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  protocol     Protocol

  // Ownership
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // OIDC Specific Fields
  issuerUrl    String?
  clientId     String?
  clientSecret String? // Encrypted at rest (AES-256-GCM)
  scopes       String? @default("openid profile email")

  // SAML Specific Fields
  entryPoint   String? // Identity Provider Single Sign-On URL
  issuer       String? // Service Provider Entity ID
  idpCert      String? // The IDP Public Certificate — encrypted at rest

  // UI Customization
  buttonColor  String? @default("#3B71CA")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Protocol {
  OIDC
  SAML
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum TeamJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthTokenPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}
