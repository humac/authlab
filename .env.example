# ─────────────────────────────────────────────────────────────────────
# AuthLab Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
#
# Three deployment modes:
#   1. Local dev (no Docker)  — SQLite, next dev
#   2. Docker (self-hosted)   — SQLite in container volume, next start
#   3. Production (Vercel)    — Turso remote DB, Vercel deployment
# ─────────────────────────────────────────────────────────────────────

# ── Required (all modes) ────────────────────────────────────────────

# AES-256-GCM master key for encrypting secrets at rest.
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY="generate-a-64-char-hex-string-using-openssl-rand-hex-32"

# iron-session cookie encryption password (min 32 chars).
# Generate with: openssl rand -hex 32
SESSION_PASSWORD="generate-a-64-char-hex-string-using-openssl-rand-hex-32"

# Public-facing URL of the app. Used for OIDC/SAML callbacks and email links.
#   Local dev:    http://localhost:3000
#   Docker:       http://localhost:3000  (or your Docker host)
#   Production:   https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database ────────────────────────────────────────────────────────

# Local dev + Docker (SQLite):
#   For local dev without Docker:
#     DATABASE_URL="file:./dev.db"
#   For Docker (matches the mounted volume path):
#     DATABASE_URL="file:/app/data/dev.db"
DATABASE_URL="file:./dev.db"

# Production (Turso/libSQL) — when both are set, SQLite is ignored:
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── SAML (optional) ────────────────────────────────────────────────

# Legacy global SAML SP signing material. Per-app keys are preferred
# and can be generated in the UI. Leave blank if not needed.
# SAML_SP_PRIVATE_KEY=""
# SAML_SP_PUBLIC_CERT=""
